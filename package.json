{
  "name": "jls-transitshield",
  "version": "1.0.0",
  "private": true,
  "description": "TransitShield — an NYC subway climate-resilience risk index. Which stations fail first when the climate turns — and who gets stranded. Portfolio project by Jean-Luc Saint-Fleur.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "data": "python3 scripts/build_index.py",
    "validate": "python3 scripts/validate/validate_outputs.py"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1",
    "next": "^15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
